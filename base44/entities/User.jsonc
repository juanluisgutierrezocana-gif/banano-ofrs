{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "description": "The role of the user in the app",
      "enum": [
        "admin",
        "user"
      ]
    },
    "session_token": {
      "type": "string",
      "description": "Token de sesi\u00f3n activa para control de sesi\u00f3n \u00fanica"
    }
  },
  "required": [
    "role"
  ]
}